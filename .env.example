# Project
PROJECT_NAME=Hybrid AI for Predictive Maintenance
ENVIRONMENT=development

# Database
DATABASE_PATH=data/hybrid_ai_predictive_maintenance.sqlite3

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG
VECTOR_STORE_PATH=knowledge_base/vector_store
KNOWLEDGE_BASE_RAW_PATH=knowledge_base/raw
KNOWLEDGE_BASE_PROCESSED_PATH=knowledge_base/processed

# Text-to-SQL
ALLOW_ONLY_SELECT_QUERIES=true
MAX_SQL_ROWS=100

# App
STREAMLIT_APP_TITLE=Hybrid AI for Predictive Maintenance
DEFAULT_ASSET_ID=1
DEFAULT_SCENARIO=normal_operation

# Monitoring
ENABLE_ACTION_LOGS=true
LOG_PATH=logs/app.log